# BullWave Capital — Docker environment
# Copy to project root:  copy .env.docker.example .env
# Then edit KOTAK_NEO_ACCESS_TOKEN (required for live prices).

SECRET_KEY=docker-dev-secret-change-me
DEBUG=True
ALLOWED_HOSTS=*

# Database — host is overridden to "db" by docker-compose
DB_NAME=bullwave_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# ── Market data (Kotak Neo) ──
# Kotak Neo app → More → TradeAPI → API Dashboard → Access Token
KOTAK_NEO_ACCESS_TOKEN=your-kotak-neo-access-token
KOTAK_NEO_BASE_URL=https://mis.kotaksecurities.com
MARKET_DATA_PROVIDER=kotak_neo

# ── Dev-friendly defaults (no extra keys needed) ──
SMS_PROVIDER=console
KYC_AUTO_APPROVE=True
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# ── AI — Ollama runs in Docker (ollama service) ──
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=2048
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=350
AI_REQUEST_TIMEOUT=90

# Optional — leave empty for demo
FINNHUB_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
OPENAI_API_KEY=
GROQ_API_KEY=
