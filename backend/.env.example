SECRET_KEY=change-me-in-production

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2



# ── Database (PostgreSQL) ──

DB_NAME=bullwave_db

DB_USER=postgres

DB_PASSWORD=postgres

DB_HOST=localhost

DB_PORT=5432



# ── Market data — Kotak Neo Trade API (real-time NSE/BSE) ──
# Kotak Neo app → More → TradeAPI → API Dashboard → Access Token
KOTAK_NEO_ACCESS_TOKEN=your-kotak-neo-access-token
KOTAK_NEO_BASE_URL=https://mis.kotaksecurities.com
KOTAK_NEO_QUOTE_CACHE_SECONDS=15
KOTAK_NEO_UNIVERSE_CACHE_SECONDS=15
KOTAK_NEO_BATCH_SIZE=50
MARKET_DATA_PROVIDER=kotak_neo

# Optional fallbacks
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

MARKET_QUOTE_CACHE_SECONDS=30

MARKET_UNIVERSE_CACHE_SECONDS=60

NEWS_CACHE_MINUTES=15



# ── SMS OTP — console (dev) | msg91 | twilio ──

SMS_PROVIDER=console

MSG91_AUTH_KEY=

MSG91_TEMPLATE_ID=

TWILIO_ACCOUNT_SID=

TWILIO_AUTH_TOKEN=

TWILIO_FROM_NUMBER=

TWILIO_SERVICE_SID=

TWILIO_VERIFY_CHANNEL=sms

# ── Payments — Razorpay (https://dashboard.razorpay.com) ──

RAZORPAY_KEY_ID=

RAZORPAY_KEY_SECRET=

RAZORPAY_WEBHOOK_SECRET=



# ── Cashfree Secure ID & Payments (leave empty — load from dashboard) ──
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_ENVIRONMENT=
SECURE_ID_BASE_URL=
SECURE_ID_API_KEY=
SECURE_ID_API_SECRET=
CASHFREE_PAYMENTS_BASE_URL=
CASHFREE_PAYOUTS_BASE_URL=
CASHFREE_PAYMENT_WEBHOOK_SECRET=
CASHFREE_PAYOUT_WEBHOOK_SECRET=
CASHFREE_API_VERSION=2022-10-26
CASHFREE_PAYMENT_API_VERSION=2023-08-01



# ── Compliance ──

# Sandbox/dev: auto-approve KYC when Cashfree IP is not whitelisted (never applies in production).
KYC_AUTO_APPROVE=True

REFERRAL_REWARD_AMOUNT=500
APP_SHARE_URL=https://bullwave.in

OTP_EXPIRY_MINUTES=5

# ── Manual KYC admin email (production) ──
# Brevo (recommended): HTML emails with Approve/Reject buttons
EMAIL_PROVIDER=brevo  # smtp | sendgrid | brevo
ADMIN_KYC_EMAIL=bullwaveteam5@gmail.com
# Public API URL — required for email approve/reject links (use ngrok in local dev)
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# Brevo — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=BullWave Capital

# SendGrid (alternative)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# SMTP (fallback / dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@bullwave.app



# ── AI — Ollama (local) or cloud ──

AI_PROVIDER=ollama

OLLAMA_BASE_URL=http://127.0.0.1:11434

OLLAMA_MODEL=llama3.2:1b

OLLAMA_KEEP_ALIVE=30m

OLLAMA_NUM_CTX=2048

AI_TEMPERATURE=0.4

AI_MAX_TOKENS=350

AI_REQUEST_TIMEOUT=90

OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=

GROQ_MODEL=llama-3.1-8b-instant



# ── Broker APIs (future — live trading like Dhan/Zerodha) ──

KITE_API_KEY=

KITE_API_SECRET=

DHAN_CLIENT_ID=

DHAN_ACCESS_TOKEN=
